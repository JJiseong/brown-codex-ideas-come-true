# Required: server-side only. Never expose this in browser code.
OPENAI_API_KEY=sk-...

# Optional. Pick the model your company allows.
OPENAI_MODEL=gpt-5.5

# Optional. Defaults to https://api.openai.com/v1/responses
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# Optional safety controls
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_OUTPUT_TOKENS=4000
RATE_LIMIT_MAX=20
